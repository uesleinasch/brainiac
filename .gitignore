# Brainiac-specific overrides — neutralize global gitignore for files
# that ARE part of this project (this repo is about the AI workflow itself)
!CLAUDE.md
!/docs/
!/.claude/

# Python build/test artifacts
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.coverage
htmlcov/
build/
dist/

# Brainiac runtime cache (reconstructible from .md via `brainiac reindex`)
memoryTransfer/index.sqlite
memoryTransfer/index.sqlite-shm
memoryTransfer/index.sqlite-wal
