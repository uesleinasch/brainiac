# Python build/test artifacts
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.coverage
htmlcov/
build/
dist/

# Brainiac runtime cache (reconstructible from .md via `brainiac reindex`)
memoryTransfer/index.sqlite
memoryTransfer/index.sqlite-shm
memoryTransfer/index.sqlite-wal

# Brainiac runtime content — your personal notes are NEVER committed.
# Memory dirs ship empty; users fill them locally.
longMemory/**/*.md
shortMemory/**/*.md
semanticMemory/**/*.md
memoryTransfer/logs/
memoryTransfer/archive/

# Local agent / IDE configs
.claude/settings.local.json
.idea/
.vscode/

# Internal docs (not part of the open-source release)
CLAUDE.md
docs/superpowers/

# Override global gitignore that ignores /docs/ — we ship docs/MAINTAINING.md
!docs/
!docs/MAINTAINING.md

# Loose scratch files
*.html
